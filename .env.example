HARDCOVER_GRAPHQL_URL=https://api.hardcover.app/v1/graphql
HARDCOVER_API_KEY=

# Docker/Compose frontend runtime API base URL. In production this should
# point at your public backend origin, for example https://api.example.com.
VITE_API_BASE_URL=http://localhost:8000

# Runtime data defaults. Override these for local development if you do not
# want to use a mounted /data volume.
HARDCOVER_DB_PATH=/data/hardcover.db
HARDCOVER_MODEL_PATH=/data/svd_model.npz

# Comma-separated list of allowed browser origins for the backend.
HARDCOVER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional tuning knobs.
HARDCOVER_GENRE_MIN_COUNT=3
HARDCOVER_DECADE_BASE_YEAR=1900
